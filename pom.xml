					<artifactId>PlayerAnimator</artifactId>
				</exclusion>
				<exclusion>
					<groupId>me.gabytm.util</groupId>
					<artifactId>actions-spigot</artifactId>
				</exclusion>
				<exclusion>
					<groupId>net.kyori</groupId>
					<artifactId>*</artifactId>
				</exclusion>
				<exclusion>
					<groupId>com.jeff_media</groupId>
					<artifactId>*</artifactId>
				</exclusion>
			</exclusions>
		</dependency>
		<dependency>
			<groupId>me.NoChance.PvPManager</groupId>
			<artifactId>pvpmanager</artifactId>
			<version>3.18.5</version>
			<scope>provided</scope>
		</dependency>
		<dependency>
			<groupId>net.essentialsx</groupId>
			<artifactId>EssentialsX</artifactId>
			<version>2.19.0</version>
			<scope>provided</scope>
			<exclusions>
				<exclusion>
					<groupId>io.papermc</groupId>
					<artifactId>paperlib</artifactId>
				</exclusion>
				<exclusion>
					<groupId>org.bstats</groupId>
					<artifactId>bstats-bukkit</artifactId>
				</exclusion>
			</exclusions>
		</dependency>
	</dependencies>
	<build>
		<resources>
			<resource>
				<directory>src/main/resources</directory>
				<filtering>true</filtering>
			</resource>
		</resources>
		<defaultGoal>install</defaultGoal>
		<plugins>
			<plugin>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.8.1</version>
				<configuration>
					<source>1.8</source>
					<target>1.8</target>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<version>3.2.0</version>
				<configuration>
					<outputDirectory>${projects.exportFolder}</outputDirectory>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-shade-plugin</artifactId>
				<version>3.2.4</version>
				<executions>
					<execution>
						<phase>package</phase>
						<goals>
							<goal>shade</goal>
						</goals>
						<configuration>
							<relocations>
								<relocation>
									<pattern>org.bstats</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils.bStats</shadedPattern>
								</relocation>
								<relocation>
									<pattern>javax.annotation</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils.ExternalLibs.javax.annotation</shadedPattern>
								</relocation>
								<relocation>
									<pattern>javassist</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils.ExternalLibs.javassist</shadedPattern>
								</relocation>
								<relocation>
									<pattern>org.reflections</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils.ExternalLibs.org.reflections</shadedPattern>
								</relocation>
								<relocation>
									<pattern>org.slf4j</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils.ExternalLibs.org.slf4j</shadedPattern>
								</relocation>
								<relocation>
									<pattern>relampagorojo93.LibsCollection</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.LibsCollection</shadedPattern>
								</relocation>
								<relocation>
									<pattern>darkpanda73.LibsCollection</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.LibsCollection</shadedPattern>
								</relocation>
								<relocation>
									<pattern>darkpanda73.PandaUtils</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.PandaUtils</shadedPattern>
								</relocation>
								<relocation>
									<pattern>company.pluginName</pattern>
									<shadedPattern>
										${project.package}.${project.groupId}.Plugin</shadedPattern>
								</relocation>
							</relocations>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
</project>